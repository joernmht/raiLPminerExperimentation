# Copy to .env (gitignored, chmod 600) and fill in real values:
#   cp .env.example .env && chmod 600 .env && nano .env
# Real environment variables take precedence over this file.

# --- Elsevier (Phase 2) ----------------------------------------------------
# ONE Elsevier APIKey covers both ScienceDirect (full-text XML + MathML) and
# Scopus (authoritative cited-by). Register at https://dev.elsevier.com.
# For licensed FULL-TEXT text-and-data-mining you also need an institutional
# token (insttoken) from the TU Dresden library / Elsevier; without it you get
# metadata + open-access only.
ELSEVIER_API_KEY=
ELSEVIER_INSTTOKEN=
# Optional separate Scopus key; if blank, ELSEVIER_API_KEY is used for Scopus too.
SCOPUS_API_KEY=

# --- DeepSeek (LLM-assist) -------------------------------------------------
# Bulk formula transcription/verification suggestions (temperature 0). Escalate
# hard cases to Claude. OpenAI-compatible endpoint; only the key is required.
DEEPSEEK_API_KEY=

# --- OpenAlex (Phase 1, no key needed) -------------------------------------
# Polite-pool contact e-mail for stabler rate limits.
OPENALEX_MAILTO=joern.maurischat@tu-dresden.de
