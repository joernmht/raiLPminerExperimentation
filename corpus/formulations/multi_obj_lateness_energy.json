{
  "schema_version": "0.1.0",
  "id": "multi_obj_lateness_energy",
  "name": "Multi-objective lateness vs energy",
  "family": "milp",
  "description": "Demonstrates objective-as-first-class: a weighted sum over a lateness term and a per-train energy-consumption term, with explicit per-term weights.",
  "tags": ["milp", "multi-objective", "weighted-sum"],
  "indices": [
    { "name": "I", "description": "Trains.", "ordered": true }
  ],
  "parameters": [
    { "name": "w_late", "kind": "scalar", "description": "Lateness weight." },
    { "name": "w_energy", "kind": "scalar", "description": "Energy weight." },
    { "name": "e", "shape": ["I"], "kind": "vector", "description": "Per-train energy coefficient." }
  ],
  "variables": [
    { "name": "t", "shape": ["I"], "domain": "non_negative", "description": "Departure time." },
    { "name": "v", "shape": ["I"], "domain": "non_negative", "description": "Cruising speed proxy." },
    { "name": "z", "shape": ["I"], "domain": "binary", "description": "1 if train i runs at all." }
  ],
  "constraints": [
    {
      "name": "must_run",
      "kind": "linear",
      "description": "If z_i = 1 then v_i is bounded below.",
      "quantifiers": [{ "index": "i", "over": "I" }],
      "comparator": "ge",
      "lhs": [{ "ref": "v", "ref_kind": "variable", "bindings": [{ "index": "I", "expr": "i" }], "role": "lhs" }],
      "rhs": [{ "ref": "z", "ref_kind": "variable", "bindings": [{ "index": "I", "expr": "i" }], "role": "rhs" }]
    }
  ],
  "objective": {
    "sense": "min",
    "name": "weighted_sum",
    "description": "Two named objective terms combined as a weighted sum.",
    "combination": "weighted_sum",
    "terms": [
      { "ref": "t", "ref_kind": "variable", "bindings": [{ "index": "I", "expr": "i" }], "coefficient": "w_late", "operator": "sum", "operator_over": ["I"], "role": "objective" },
      { "ref": "v", "ref_kind": "variable", "bindings": [{ "index": "I", "expr": "i" }], "coefficient": "w_energy", "operator": "sum", "operator_over": ["I"], "role": "objective" },
      { "ref": "e", "ref_kind": "parameter", "bindings": [{ "index": "I", "expr": "i" }], "operator": "sum", "operator_over": ["I"], "role": "objective" }
    ]
  }
}
